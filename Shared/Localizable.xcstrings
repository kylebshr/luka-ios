    "Fetch glucose readings from the Luka server when a Live Activity is running. Falls back to Dexcom if no cached readings are available." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ruft Glukosemesswerte vom Luka-Server ab, während eine Live-Aktivität läuft. Greift auf Dexcom zurück, wenn keine zwischengespeicherten Messwerte verfügbar sind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obtén lecturas de glucosa del servidor de Luka cuando haya una Actividad en Vivo en ejecución. Recurre a Dexcom si no hay lecturas en caché disponibles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Récupère les mesures de glycémie depuis le serveur Luka lorsqu’une activité en direct est en cours. Utilise Dexcom si aucune mesure en cache n’est disponible."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Récupère les mesures de glycémie depuis le serveur Luka lorsqu’une activité en direct est en cours. Utilise Dexcom si aucune mesure en cache n’est disponible."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Henter glukosemålinger fra Luka-serveren mens en Live Activity kjører. Bruker Dexcom hvis ingen bufrede målinger er tilgjengelige."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hämtar glukosvärden från Luka-servern när en Live Activity körs. Faller tillbaka på Dexcom om inga cachade värden finns tillgängliga."
          }
        }
      }
    },
