    "Live Activities are disabled." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Live-Aktivitäten sind deaktiviert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Live Activities are disabled."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las Actividades en Vivo están desactivadas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les activités en direct sont désactivées."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les activités en direct sont désactivées."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Live Activities er deaktivert."
          }
