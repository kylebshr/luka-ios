    "Sign In" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anmelden"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sign In"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iniciar sesión"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se connecter"
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se connecter"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Logg inn"
          }
        },
        "sv" : {
